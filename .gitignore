# .gitignore — Escriba

# Ambiente virtual Python
.venv/
venv/
env/
/.agent
# Cache Python
__pycache__/
*.py[cod]
*.pyo

# Artefato de áudio temporário (nunca deve ser versionado)
temp_meeting.wav

# Logs da aplicação
.logs/

# Cache do modelo Whisper (binário grande, re-baixado automaticamente)
.cache/whisper/

# Outputs de transcrição gerados pelo app
*.txt
*.md
!README.md
!.agent/*.md

# IDEs
.vscode/
.idea/
*.swp

# OS
Thumbs.db
.DS_Store
